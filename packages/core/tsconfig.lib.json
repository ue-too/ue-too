{
    "extends": "./tsconfig.json",
    "compilerOptions": {
        "baseUrl": "./",
        "paths": {
            "src": ["src"],
            "src/*": ["src/*"],
            "coordinate-conversion": ["src/board-camera/coordinate-conversion"]
        },
        "outDir": "./build"
    },
    "include": [ "src/**/*" ],
    "exclude": ["node_modules", "**/*.test.ts", "dist", "build", "devserver/**/*", "tests/**/*"]
}