{
  "name": "@ue-too/core",
  "version": "0.5.0",
  "description": "Core functionality for ue-too - pan, zoom, and rotate your html canvas",
  "main": "../../build/packages/core/index.cjs.js",
  "module": "../../build/packages/core/index.esm.js",
  "types": "../../build/packages/core/index.d.ts",
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rollup -c --bundleConfigAsCjs rollup.config.js && pnpm exec tsc-alias -p ./tsconfig.lib.json && pnpm run move-package",
    "build:nx": "nx build core",
    "rollup": "rollup -c --bundleConfigAsCjs",
    "watch": "rollup -c --bundleConfigAsCjs rollup.config.js --watch",
    "test": "nx test core",
    "lint": "nx lint core",
    "move-package": "node ../../scripts/move-package.mjs"
  },
  "dependencies": {
    "point2point": "^0.0.95"
  },
  "keywords": [
    "canvas",
    "infinite-canvas",
    "pixi.js",
    "PIXI",
    "camera",
    "board",
    "input"
  ],
  "author": "niuee",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ue-too/ue-too.git"
  },
  "bugs": {
    "url": "https://github.com/ue-too/ue-too/issues"
  },
  "homepage": "https://github.com/ue-too/ue-too#readme"
} 