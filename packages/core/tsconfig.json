{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "module": "esnext",
    "baseUrl": "./",
    "outDir": "./build",
    "resolveJsonModule": true,
    "paths": {
      "src": ["src"],
      "src/*": ["./src/*"],
      "coordinate-conversion": ["src/board-camera/coordinate-conversion"]
