{
  "name": "math",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/math/src",
  "projectType": "library",
  "tags": [],
  "// targets": "to see all targets run: nx show project math --web",
  "targets": {
    "build": {
      "executor": "@nx/rollup:rollup",
      "outputs": ["{workspaceRoot}/build/packages/math"],
      "options": {
        "main": "packages/math/src/index.ts",
        "tsConfig": "packages/math/tsconfig.lib.json",
        "outputPath": "build/packages/math",
        "useLegacyTypescriptPlugin": false,
        "format": ["cjs", "esm"],
        "fileName": "index"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "outputs": ["{options.outputFile}"]
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "jestConfig": "packages/math/jest.config.ts"
      }
    }
  }
}
