{
  "name": "math",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/math/src",
  "projectType": "library",
  "tags": [],
  "// targets": "to see all targets run: nx show project math --web",
  "targets": {
    "clean": {
      "executor": "nx:run-commands",
      "options": {
        "command": "node ../../scripts/clean-package.mjs",
        "cwd": "packages/math"
      }
    },
    "rollup": {
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/build/packages/math"],
      "dependsOn": ["clean"],
      "options": {
        "command": "npx rollup -c rollup.config.js",
        "cwd": "packages/math"
      }
    },
    "build": {
      "executor": "nx:run-commands",
      "dependsOn": ["rollup"],
      "options": {
        "command": "node ../../scripts/move-package.mjs",
        "cwd": "packages/math"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "outputs": ["{options.outputFile}"]
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "jestConfig": "packages/math/jest.config.ts"
      }
    }
  }
}
