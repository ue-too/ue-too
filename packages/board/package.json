{
    "name": "@ue-too/board",
    "type": "module",
    "version": "0.17.4",
    "exports": {
        ".": {
            "types": "./src/index.ts",
            "import": "./src/index.ts",
            "default": "./src/index.ts"
        },
        "./boardify": {
            "types": "./src/boardify/index.ts",
            "import": "./src/boardify/index.ts",
            "default": "./src/boardify/index.ts"
        },
        "./camera": {
            "types": "./src/camera/index.ts",
            "import": "./src/camera/index.ts",
            "default": "./src/camera/index.ts"
        },
        "./input-interpretation": {
            "types": "./src/input-interpretation/index.ts",
            "import": "./src/input-interpretation/index.ts",
            "default": "./src/input-interpretation/index.ts"
        },
        "./utils": {
            "types": "./src/utils/index.ts",
            "import": "./src/utils/index.ts",
            "default": "./src/utils/index.ts"
        },
        "./*": {
            "types": "./src/*/index.ts",
            "import": "./src/*/index.ts",
            "default": "./src/*/index.ts"
        },
        "./package.json": "./package.json"
    },
    "main": "./src/index.ts",
    "types": "./src/index.ts",
    "module": "./src/index.ts",
    "dependencies": {
        "@ue-too/being": "workspace:*",
        "@ue-too/math": "workspace:*"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/ue-too/ue-too.git"
    },
    "author": "niuee",
    "license": "MIT",
    "bugs": {
        "url": "https://github.com/ue-too/ue-too/issues"
    },
    "homepage": "https://github.com/ue-too/ue-too#readme",
    "keywords": [
        "canvas",
        "infinite-canvas",
        "pixi.js",
        "PIXI"
    ],
    "scripts": {
        "test": "jest",
        "build:legacy": "rm -rf dist && rollup -c rollup.config.js"
    }
}
