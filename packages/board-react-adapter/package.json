{
    "name": "@ue-too/board-react-adapter",
    "type": "module",
    "version": "0.17.0",
    "repository": {
        "type": "git",
        "url": "https://github.com/ue-too/ue-too.git"
    },
    "homepage": "https://github.com/ue-too/ue-too",
    "scripts": {
        "test": "jest",
        "build:legacy": "rm -rf dist && rollup -c rollup.config.js"
    },
    "exports": {
        ".": {
            "types": "./src/index.ts",
            "import": "./src/index.ts",
            "default": "./src/index.ts"
        },
        "./components": {
            "types": "./src/components/index.ts",
            "import": "./src/components/index.ts",
            "default": "./src/components/index.ts"
        },
        "./hooks": {
            "types": "./src/hooks/index.ts",
            "import": "./src/hooks/index.ts",
            "default": "./src/hooks/index.ts"
        },
        "./*": {
            "types": "./src/*/index.ts",
            "import": "./src/*/index.ts",
            "default": "./src/*/index.ts"
        },
        "./package.json": "./package.json"
    },
    "license": "MIT",
    "main": "./src/index.ts",
    "types": "./src/index.ts",
    "module": "./src/index.ts",
    "dependencies": {
        "@ue-too/board": "workspace:*",
        "@ue-too/math": "workspace:*"
    },
    "peerDependencies": {
        "react": "^19.0.1",
        "react-dom": "^19.0.1"
    },
    "devDependencies": {
        "react": "^19.0.1",
        "react-dom": "^19.0.1"
    }
}
